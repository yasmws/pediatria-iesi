@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title Diagrama de Componentes (C4) - Digitalização de Formulários (GAS)

Person(recepcionista, "Recepcionista")
Person(medico, "Profissional de Saúde")

System_Ext(aghu, "AGHU", "Sistema de Gestão Hospitalar")

Container_Boundary(system, "Sistema de Atendimento") {

    Component(ui_atendimento, "UI Atendimento", "Web App", "Tela para atendimento clínico")
    Component(ui_recepcao, "UI Recepção", "Web App", "Check-in e agendamento")

    Component(atendimento_service, "Atendimento Service", "Backend", "Orquestra o fluxo do atendimento")
    Component(triagem_service, "Triagem Service", "Backend", "Anamnese e coleta de dados")
    Component(avaliacao_service, "Avaliação Clínica", "Backend", "Cálculo IMC, curvas, etc")
    Component(encaminhamento_service, "Encaminhamento Service", "Backend", "Encaminha para especialidades")
    Component(agendamento_service, "Agendamento Service", "Backend", "Gerencia marcação de consultas")

    Component(aghu_integration, "Integração AGHU", "API Client", "Comunicação com sistema hospitalar")

    ComponentDb(db, "Banco de Dados", "Database", "Dados clínicos e pacientes")
}

' Relacionamentos dos Atores com as UIs
Rel(recepcionista, ui_recepcao, "Usa")
Rel(medico, ui_atendimento, "Usa")

' Relacionamentos UIs -> Backend
Rel(ui_atendimento, atendimento_service, "Envia dados do atendimento")
Rel(ui_recepcao, agendamento_service, "Agenda consulta")

' Orquestração do Atendimento
Rel(atendimento_service, triagem_service, "Solicita triagem")
Rel(atendimento_service, avaliacao_service, "Solicita avaliação")
Rel(atendimento_service, encaminhamento_service, "Solicita encaminhamento")
Rel(atendimento_service, aghu_integration, "Consulta/Envia prontuário")

' Serviços -> Banco de Dados
Rel(triagem_service, db, "Salva dados")
Rel(avaliacao_service, db, "Salva avaliação")
Rel(encaminhamento_service, db, "Registra encaminhamento")
Rel(agendamento_service, db, "Salva agendamento")

' Integrações
Rel(aghu_integration, aghu, "Lê histórico e salva prontuário via API")

@enduml